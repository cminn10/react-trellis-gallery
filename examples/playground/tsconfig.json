{
	"compilerOptions": {
		"target": "ES2020",
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleDetection": "force",
		"jsx": "react-jsx",
		"moduleResolution": "bundler",
		"types": ["vite/client", "node"],
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"skipLibCheck": true,
		"paths": {
			"react-trellis-gallery": ["../../src/index.ts"]
		}
	},
	"include": ["src", "vite.config.ts"]
}
